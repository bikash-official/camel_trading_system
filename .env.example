# ─── LLM API Keys (pick one or more) ─────────────────────────────────────────
# CAMEL supports OpenAI, Anthropic, Groq, Mistral, and many more.
# At least ONE key is required for the CAMEL agents to work.

OPENAI_API_KEY=your_openai_api_key_here

# Optional alternatives:
# ANTHROPIC_API_KEY=your_anthropic_key_here
# GROQ_API_KEY=your_groq_key_here          ← FREE tier available
# GEMINI_API_KEY=your_gemini_key_here

# ─── CAMEL Logging (optional) ─────────────────────────────────────────────────
CAMEL_MODEL_LOG_ENABLED=false
CAMEL_LOG_DIR=logs
